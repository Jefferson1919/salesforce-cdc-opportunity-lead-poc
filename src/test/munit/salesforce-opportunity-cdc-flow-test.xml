            http://www.mulesoft.org/schema/mule/db/current/mule-db.xsd
        http://www.mulesoft.org/schema/mule/azure-service-bus-messaging
            http://www.mulesoft.org/schema/mule/azure-service-bus-messaging/current/mule-azure-service-bus-messaging.xsd">

    <munit:config name="salesforce-opportunity-cdc-flow-test"/>

    <!-- ================================================================
         TEST 1 — CREATE changeType → deve chamar db:insert
         Cobre: set-variable(x2), azure:send(archive), until-successful,
                idempotent-validator, logger(x2), ee:transform, foreach,
                choice(CREATE branch), db:insert, logger(after insert)
         ================================================================ -->
    <munit:test name="test-opportunity-cdc-create"
                description="Opportunity CDC CREATE: roteia para db:insert (upsert)">
        <munit:behavior>
            <munit-tools:mock-when doc:name="Mock Azure archive send"
                                   processor="azure-service-bus-messaging:send">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name"
                                                whereValue="#['sf-opportunity-sync-events-archive-queue']"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return/>
            </munit-tools:mock-when>

            <munit-tools:mock-when doc:name="Mock idempotent validator"
                                   processor="mule:idempotent-message-validator">
                <munit-tools:then-return/>
            </munit-tools:mock-when>

            <munit-tools:mock-when doc:name="Mock db:insert"
                                   processor="db:insert">
                <munit-tools:then-return>
                    <munit-tools:payload value='#[{ affectedRows: 1 }]'
                                         mediaType="application/java"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit-tools:mock-when doc:name="Mock Azure errors send (safety)"
                                   processor="azure-service-bus-messaging:send">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name"
                                                whereValue="#['sf-opportunity-sync-errors-queue']"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return/>
            </munit-tools:mock-when>
        </munit:behavior>

        <munit:execution>
            <munit:set-event doc:name="Set Opportunity CDC CREATE event">
                <munit:payload mediaType="application/java" value='#[{
                    data: {
                        schema: "OpportunityChangeEventSchema",
                        payload: {
                            Name: "New Enterprise Deal",
                            Amount: 80000.0,
                            StageName: "Prospecting",
                            CloseDate: "2026-06-30",
                            Probability: 20.0,
                            AccountId: "001gL00001ABCDeQAL",
                            OwnerId: "005gL00000BNrrhQAD",
                            Type: "New Customer",
                            LeadSource: "Web",
                            CurrencyIsoCode: "USD",
                            Description: "New deal for testing CREATE.",
                            CreatedDate: "2026-03-19T10:00:00.000Z",
                            LastModifiedDate: "2026-03-19T10:00:00.000Z",
                            ChangeEventHeader: {
                                entityName: "Opportunity",
                                changeType: "CREATE",
                                changedFields: [],
                                changeOrigin: "com/salesforce/api/soap/66.0;client=SfdcInternalAPI/",
                                transactionKey: "aaaabbbb-cccc-dddd-eeee-ffff00001111",
                                commitTimestamp: 1774000000000,
                                recordIds: ["006gL00000XYZAbQAL"]
                            }
                        },
                        event: { replayId: 950100 }
                    },
                    channel: "/data/OpportunityChangeEvent",
                    timestamp: "2026-03-19T10:00:01.000Z"
                }]'/>
            </munit:set-event>
            <flow-ref doc:name="Executa salesforce-opportunity-cdc-flow"
                      name="salesforce-opportunity-cdc-flow"/>
        </munit:execution>

        <munit:validation>
            <munit-tools:verify-call doc:name="db:insert deve ser chamado 1 vez"
                                     processor="db:insert" times="1"/>
            <munit-tools:verify-call doc:name="db:delete não deve ser chamado"
                                     processor="db:delete" times="0"/>
            <munit-tools:verify-call doc:name="Azure archive send deve ser chamado"
                                     processor="azure-service-bus-messaging:send" times="1">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name"
                                                whereValue="#['sf-opportunity-sync-events-archive-queue']"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

